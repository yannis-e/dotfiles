# i3blocks configuration file
#
# The i3blocks man page describes the usage of the binary,
# and its website describes the configuration:
#
#     https://vivien.github.io/i3blocks


# Global properties
separator=true
separator_block_width=15
markup=pango

[network]
command=~/.local/bin/i3blocks-network
interval=5
markup=pango

[time]
label= 
command=date '+%Y-%m-%d %H:%M'
interval=1
color=#f1fa8c

[power]
full_text=󰐥 
color=#ff5555
command=~/.local/bin/rofi-power-menu
BLOCK_BUTTON=1
